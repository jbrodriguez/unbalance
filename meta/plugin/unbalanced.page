<script type="text/javascript">
$(function(){
	showStatus('<?=$sName;?>');
	checkRUNNING(document.unbalanced_settings);
});

function checkRUNNING(form) {
	// PORT (.stopped) is only editable when the daemon is stopped. SERVICE and the
	// auth fields can always be edited; Apply is always enabled because every
	// permutation has something the form can legitimately submit:
	//   running   + enable  → restart with new env (start does killall+launch)
	//   running   + disable → run stop script
	//   stopped   + enable  → run start script
	//   stopped   + disable → save cfg, stop is a no-op
	if (<?=$unbalanced_running;?> == 1) {
		$(".stopped").prop("disabled", true);
	} else {
		$(".stopped").prop("disabled", (form.SERVICE.value == "enable"));
	}
	form.btnApply.disabled = false;
	if (form.SERVICE.value == "enable")
		form.command.value = "/usr/local/emhttp/plugins/unbalanced/scripts/start";
	else
		form.command.value = "/usr/local/emhttp/plugins/unbalanced/scripts/stop";
}

