function verifyDATA(form) {
	if (isNaN(form.PORT.value)){
		form.PORT.value = "7090";
	} else {
		if (form.PORT.value < 0 || form.PORT.value > 65535){
			form.PORT.value = "7090";
		}
	}
	form.SERVICE.value = form.SERVICE.value.replace(/ /g,"_");
	form.PORT.value = form.PORT.value.replace(/ /g,"_");
	form.AUTH_ENABLED.value = form.AUTH_ENABLED.value.replace(/ /g,"_");
	form.AUTH_USERNAME.value = form.AUTH_USERNAME.value.replace(/ /g,"_");
}

function applyDATA(form) {
	verifyDATA(form);
	form.submit();
}

</script>
